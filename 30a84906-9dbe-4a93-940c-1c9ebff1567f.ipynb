   "source": [
    "# Сортировка по пользователю и дате\n",
    "df_filtered = df_filtered.sort_values(['user_id', 'order_dt'])\n",
    "\n",
    "# Базовый профиль\n",
    "user_profile = df_filtered.groupby('user_id').agg(\n",
    "    first_order_date = ('order_dt', 'min'),\n",
    "    last_order_date = ('order_dt', 'max'),\n",
    "    total_orders = ('order_id', 'count'),\n",
    "    total_revenue_rub = ('revenue_rub', 'sum'),\n",
    "    avg_revenue_rub = ('revenue_rub', 'mean'),\n",
    "    avg_tickets_count = ('tickets_count', 'mean'),\n",
    "    avg_days_between = ('days_since_prev', 'mean')\n",
    ").reset_index()\n",
    "\n",
    "# Признаки первого заказа (берём первую запись)\n",
    "first_orders = df_filtered.groupby('user_id').first().reset_index()\n",
    "first_orders = first_orders[['user_id', 'device_type_canonical', 'region_name', 'service_name', 'event_type_main']]\n",
    "first_orders.columns = ['user_id', 'first_device', 'first_region', 'first_service', 'first_event_type']\n",
    "\n",
    "user_profile = user_profile.merge(first_orders, on='user_id', how='left')\n",
    "\n",
    "# Бинарные признаки\n",
    "user_profile['is_two'] = (user_profile['total_orders'] >= 2).astype(int)\n",
    "user_profile['is_five'] = (user_profile['total_orders'] >= 5).astype(int)\n",
    "\n",
    "user_profile.head()"
   ]
