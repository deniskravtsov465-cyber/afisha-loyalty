    "def segment_distribution(df, col):\n",
    "    seg = df.groupby(col).size().reset_index(name='count')\n",
    "    seg['perc'] = seg['count'] / seg['count'].sum() * 100\n",
    "    return seg.sort_values('count', ascending=False)\n",
    "\n",
    "for col in ['first_device', 'first_event_type', 'first_region', 'first_service']:\n",
    "    print(f\"\\nСегментация по {col}:\")\n",
    "    print(segment_distribution(user_profile, col).head(10))"
   ]
